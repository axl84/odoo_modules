<odoo>

    <record id="sale_subscription_form_inherit" model="ir.ui.view">
        <field name="name">sale.subscription.form.inherit</field>
        <field name="model">sale.subscription</field>
        <field name="inherit_id" ref="subscription_oca.sale_subscription_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group" position="after">
                <group>
                    <group string="Program/Group" name="program_training">
                        <field name="program_id"/>

                        <field name="domain_group_id" invisible="1"/>
                        <field name="group_id" domain="domain_group_id" invisible="not program_id"/>
                    </group>
                    <group string="Frozen subscribe" name="frozen_subscribe" invisible="not is_frozen">
                        <field name="is_frozen" readonly="1" force_save="1"/>
                        <field name="reason_frozen" required="is_frozen"/>
                        <field name="start_frozen_date" readonly="1"/>
                        <field name="end_frozen_date" readonly="1"/>
                        <field name="frozen_days" readonly="1"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
