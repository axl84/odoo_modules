<odoo>

    <record id="view_partners_form_inherit" model="ir.ui.view">
        <field name="name">res_partner.view.form.calendar.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="calendar.view_partners_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='schedule_meeting']" position="before">
                <button class="oe_stat_button" type="object" name="action_open_subscription" icon="fa-refresh">
                    <div class="o_stat_info">
                        <span class="o_stat_text">
                            Subscriptions
                        </span>
                        <span class="o_stat_value">
                            <field name="count_subscription"/>
                        </span>
                    </div>
                </button>

                <button class="oe_stat_button" type="object" name="action_open_group" icon="fa-folder">
                    <div class="o_stat_info">
                        <span class="o_stat_text">
                            Groups
                        </span>
                        <span class="o_stat_value">
                            <field name="count_group"/>
                        </span>
                    </div>
                </button>

                <button class="oe_stat_button" type="object" name="action_open_training" icon="fa-rocket">
                    <div class="o_stat_info">
                        <span class="o_stat_text">
                            Trainings
                        </span>
                        <span class="o_stat_value">
                            <field name="count_training"/>
                        </span>
                    </div>
                </button>

                <button class="oe_stat_button" type="object" name="action_open_attendance" icon="fa-sign-in">
                    <div class="o_stat_info">
                        <span class="o_stat_text">
                            Attendance
                        </span>
                        <span class="o_stat_value">
                            <field name="count_attendance"/>
                        </span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

    <record id="view_partner_form_inherit" model="ir.ui.view">
        <field name="name">view.partner.form.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//span[@name='address_name']" position="before">
                <field name="type_parent" invisible="type_person != 'parent' or is_company"/>

                <field name="birthday"/>

                <field name="age" invisible="1"/>
                <field name="age_store" readonly="1"/>

                <field name="gender"/>
            </xpath>

            <xpath expr="//field[@name='category_id']" position="after">
                <field name="medium_id"/>

                <field name="domain_source_id" invisible="1"/>
                <field name="source_id" domain="domain_source_id"/>
                <field name="manager_promouter_id" widget="many2one_avatar_user" invisible="medium_id != 11"/>  <!--Промоутер-->
            </xpath>

            <xpath expr="//field[@name='vat']" position="after">
                <field name="class_program_id"/>
                <field name="skills_id"/>
                <field name="instagram" widget="url"/>
                <field name="telegram" widget="url"/>
            </xpath>
        </field>
    </record>

<!--    <record id="view_partner_tree_inherit" model="ir.ui.view">-->
<!--        <field name="name">view.partner.tree.inherit</field>-->
<!--        <field name="model">res.partner</field>-->
<!--        <field name="inherit_id" ref="base.view_partner_tree"/>-->
