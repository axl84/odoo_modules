<!--                <field name="age_store" optional="show"/>-->
<!--            </xpath>-->
<!--        </field>-->
<!--    </record>-->

    <record id="view_res_partner_filter" model="ir.ui.view">
        <field name="name">res.partner.select</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="class_program_id"/>
                <field name="age_store"/>
                <field name="city"/>
                <field name="company_id"/>
                <field name="user_id"/>
                <field name="medium_id" string="Channel"/>
                <field name="source_id"/>
            </xpath>

            <xpath expr="//filter[@name='type_company']" position="after">
                <separator/>
                <filter name="filter_gender_male" string="Male" domain="[('gender', '=', 'male')]"/>
                <filter name="filter_gender_female" string="Female" domain="[('gender', '=', 'female')]"/>
                <separator/>
                <filter name="group_class_program_id" string="Program" domain="[]" context="{'group_by':'class_program_id'}"/>
                <filter name="group_age_store" string="Age" domain="[]" context="{'group_by':'age_store'}"/>
                <filter name="group_gender" string="Male/Female" domain="[]" context="{'group_by':'gender'}"/>
                <filter name="group_city" string="City" domain="[]" context="{'group_by':'city'}"/>
                <filter name="group_company_id" string="Company" domain="[]" context="{'group_by':'company_id'}"/>
                <filter name="group_user_id" string="Manager" domain="[]" context="{'group_by':'user_id'}"/>
                <filter name="group_medium_id" string="Channel" domain="[]" context="{'group_by':'medium_id'}"/>
                <filter name="group_source_id" string="Source" domain="[]" context="{'group_by':'source_id'}"/>
            </xpath>
        </field>
    </record>

</odoo>
