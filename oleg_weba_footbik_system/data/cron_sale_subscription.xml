<odoo>
    <data noupdate="1">

        <record id="cron_check_subscription_start" model="ir.cron">
            <field name="name">[OLEG-WEBA] Select ready to start subscription and start</field>  <!--Выбор ожидающих подписок и активация-->
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 00:00:00')"/>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="model_id" ref="subscription_oca.model_sale_subscription"/>
            <field name="priority">5</field>
            <field name="state">code</field>
            <field name="code">model._cron_check_subscription_start()</field>
        </record>

    </data>
</odoo>
