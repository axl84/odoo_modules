<odoo>

    <record id="class_group_view_tree" model="ir.ui.view">
        <field name="name">class.group.view.tree</field>
        <field name="model">class.group</field>
        <field name="arch" type="xml">
            <tree string="Groups" default_order="create_date">
                <field name="name" optional="show"/>
                <field name="class_program_id" optional="show"/>
                <field name="trainer_id" optional="show"/>
                <field name="assistant_id" optional="show"/>
                <field name="city" optional="show"/>
                <field name="company_id" optional="show"/>
                <field name="location_id" optional="show"/>
                <field name="children_ids" widget="many2many_tags" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="class_group_view_form" model="ir.ui.view">
        <field name="name">class.group.view.form</field>
        <field name="model">class.group</field>
        <field name="arch" type="xml">
            <form string="Groups">
                <header>
                    <button name="create_training" type="object" string="Create training" class="btn btn-success"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" required="1"/>
                            <field name="start_date_for_create_training" readonly="0" required="1"/>
                            <field name="color" widget="color"/>
                            <field name="class_program_id" required="1"/>
                            <field name="trainer_id" widget="many2one_avatar_user" required="1"/>
                            <field name="assistant_id" widget="many2one_avatar_user"/>
                            <field name="city" required="1"/>
                            <field name="company_id" required="1"/>
                        </group>
                        <group>
                            <field name="photo_group" string="" widget="image" options="{'size': [256, 256]}"/>
                        </group>

                        <group string="Date/Time training" name="date_time_training">
                            <group>
                                <label for="training_on_monday"/>
                                <div class="o_row">
                                    <field name="training_on_monday" class="oe_inline"/>
                                    <field name="start_training_monday" widget="float_time" class="oe_inline"/>
                                </div>

                                <label for="training_on_tuesday"/>
                                <div class="o_row">
                                    <field name="training_on_tuesday" class="oe_inline"/>
                                    <field name="start_training_tuesday" widget="float_time" class="oe_inline"/>
                                </div>

                                <label for="training_on_wednesday"/>
                                <div class="o_row">
                                    <field name="training_on_wednesday" class="oe_inline"/>
                                    <field name="start_training_wednesday" widget="float_time" class="oe_inline"/>
                                </div>

                                <label for="training_on_thursday"/>
                                <div class="o_row">
                                    <field name="training_on_thursday" class="oe_inline"/>
                                    <field name="start_training_thursday" widget="float_time" class="oe_inline"/>
                                </div>
                            </group>
                            <group>
                                <label for="training_on_friday"/>
                                <div class="o_row">
                                    <field name="training_on_friday" class="oe_inline"/>
                                    <field name="start_training_friday" widget="float_time" class="oe_inline"/>
                                </div>

                                <label for="training_on_saturday"/>
                                <div class="o_row">
                                    <field name="training_on_saturday" class="oe_inline"/>
                                    <field name="start_training_saturday" widget="float_time" class="oe_inline"/>
                                </div>

                                <label for="training_on_sunday"/>
                                <div class="o_row">
                                    <field name="training_on_sunday" class="oe_inline"/>
                                    <field name="start_training_sunday" widget="float_time" class="oe_inline"/>
                                </div>
                            </group>
                        </group>
                        <group class="o_label_nowrap">
                            <field name="location_id" required="1"/>
                            <field name="duration_training" widget="float_time" required="1"/>
                            <field name="is_trial_training_group"/>
                            <field name="information_about_group"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Children" name="children">
                            <group>
                                <group>
                                    <field name="max_count_children" required="1"/>
                                </group>
                                <group>
                                    <field name="count_children"/>
                                </group>
                            </group>
                            <field name="children_ids" widget="many2many" nolabel="1" colspan="2">
                                <tree>
                                    <field name="name"/>
                                    <field name="phone"/>
                                    <field name="email"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Trainings" name="trainings" readonly="not training_ids">
                            <field name="training_ids" widget="many2many" nolabel="1" colspan="2">
                                <tree create="0" delete="0">
                                    <field name="name"/>
                                    <field name="state"/>
                                    <field name="location_id"/>
                                    <field name="trainer_id"/>
                                    <field name="assistant_id"/>
                                    <field name="start_training"/>
                                    <field name="end_training"/>
                                    <field name="duration_training"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="class_group_kanban" model="ir.ui.view">
        <field name="name">class.group.kanban</field>
        <field name="model">class.group</field>
        <field name="arch" type="xml">
            <kanban sample="1" default_order="create_date" default_group_by="trainer_id">
                <field name="display_name"/>
                <field name="class_program_id"/>
                <field name="trainer_id"/>
                <field name="assistant_id"/>
                <field name="count_children"/>
                <field name="city"/>
                <field name="location_id"/>
                <field name="color"/>
                <field name="create_date"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_card shadow-sm" style="border-radius: 10px; overflow: hidden;">
                            <div class="o_kanban_card_header p-3 text-white"
                                 t-att-style="'background-color: ' + record.color.raw_value">
                                <strong class="o_kanban_record_title d-block">
                                    <field name="display_name"/>
                                </strong>
                            </div>
                            <div class="o_kanban_card_body p-3 bg-light">
                                <div class="mb-2 d-flex align-items-center">
                                    <i class="fa fa-file-text-o me-2 text-secondary" aria-hidden="true"></i>
                                    <span class="text-muted">Program:</span>
                                    <span class="ms-2 fw-bold">
                                        <field name="class_program_id"/>
                                    </span>
                                </div>
                                <div class="mb-2 d-flex align-items-center">
                                    <i class="fa fa-user me-2 text-secondary" aria-hidden="true"></i>
                                    <span class="text-muted">Trainer:</span>
                                    <span class="ms-2 fw-bold">
                                        <field name="trainer_id"/>
                                    </span>
                                </div>
                                <div class="mb-2 d-flex align-items-center">
                                    <i class="fa fa-user me-2 text-secondary" aria-hidden="true"></i>
                                    <span class="text-muted">Assistant:</span>
                                    <span class="ms-2 fw-bold">
                                        <field name="assistant_id"/>
                                    </span>
                                </div>
                                <div class="mb-2 d-flex align-items-center">
                                    <i class="fa fa-users me-2 text-secondary" aria-hidden="true"></i>
                                    <span class="text-muted">Count children:</span>
                                    <span class="ms-2 fw-bold">
                                        <field name="count_children"/>
                                    </span>
                                </div>
                                <div class="mb-2 d-flex align-items-center">
                                    <i class="fa fa-map-marker me-2 text-secondary" aria-hidden="true"></i>
                                    <span class="text-muted">City:</span>
                                    <span class="ms-2 fw-bold">
                                        <field name="city"/>
                                    </span>
                                </div>
                                <div class="mb-2 d-flex align-items-center">
                                    <i class="fa fa-location-arrow me-2 text-secondary" aria-hidden="true"></i>
                                    <span class="text-muted">Location:</span>
                                    <span class="ms-2 fw-bold">
                                        <field name="location_id"/>
                                    </span>
                                </div>
                            </div>
<!--                            <div class="o_kanban_card_footer p-2 text-end text-muted">-->
<!--                                <span>-->
<!--                                    Created on: <field name="create_date"/>-->
<!--                                </span>-->
<!--                            </div>-->
                        </div>
                    </t>
                </templates>
