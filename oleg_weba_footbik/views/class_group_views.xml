<!--                        <div class="oe_kanban_global_click">-->
<!--                            <div class="oe_kanban_details d-flex flex-column justify-content-between" style="font-size: 16px;">-->
<!--                                <div>-->
<!--                                    <strong class="o_kanban_record_title oe_partner_heading"><field name="name"/></strong>-->
<!--                                    <div>-->
<!--                                        <span>Program: </span>-->
<!--                                        <field name="class_program_id"/>-->
<!--                                    </div>-->
<!--                                    <div class="fa fa-user me-2" style="font-size: 16px;">-->
<!--                                        <span>Trainer: </span>-->
<!--                                        <field name="trainer_id"/>-->
<!--                                    </div>-->
<!--                                    <div>-->
<!--                                        <span>Count children: </span>-->
<!--                                        <field name="count_children"/>-->
<!--                                    </div>-->
<!--                                    <div>-->
<!--                                        <span>City: </span>-->
<!--                                        <field name="city"/>-->
<!--                                    </div>-->
<!--                                    <div>-->
<!--                                        <span>Location: </span>-->
<!--                                        <field name="location_id"/>-->
<!--                                    </div>-->
<!--                                </div>-->
<!--                                <div class="o_kanban_record_bottom">-->
<!--                                    <div class="oe_kanban_bottom_left"/>-->
<!--                                    <div class="oe_kanban_bottom_right"/>-->
<!--                                </div>-->
<!--                            </div>-->
<!--                        </div>-->
<!--                    </t>-->
<!--                </templates>-->
            </kanban>
        </field>
    </record>

    <record id="class_group_search" model="ir.ui.view">
        <field name="name">class.group.search</field>
        <field name="model">class.group</field>
        <field name="arch" type="xml">
            <search string="Groups">
                <field name="name"/>
                <field name="class_program_id"/>
                <field name="trainer_id"/>
                <field name="assistant_id"/>
                <field name="city"/>
                <field name="location_id"/>
                <field name="is_trial_training_group"/>
                <field name="children_ids"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_class_program_id" string="Program" domain="[]" context="{'group_by':'class_program_id'}"/>
                    <filter name="group_trainer_id" string="Trainer" domain="[]" context="{'group_by':'trainer_id'}"/>
                    <filter name="group_assistant_id" string="Assistant" domain="[]" context="{'group_by':'assistant_id'}"/>
                    <filter name="group_city" string="City" domain="[]" context="{'group_by':'city'}"/>
                    <filter name="group_location_id" string="Location" domain="[]" context="{'group_by':'location_id'}"/>
                    <filter name="group_is_trial_training_group" string="Is trial training group" domain="[]" context="{'group_by':'is_trial_training_group'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_class_group" model="ir.actions.act_window">
        <field name="name">Groups</field>
        <field name="res_model">class.group</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>

    <menuitem
        id="menu_class_group"
        name="Groups"
        action="action_class_group"
        parent="root_menu_footbik"
        sequence="0"
    />

</odoo>
