<odoo>

    <record id="class_training_view_tree" model="ir.ui.view">
        <field name="name">class.training.view.tree</field>
        <field name="model">class.training</field>
        <field name="arch" type="xml">
            <tree string="Trainings" limit="84" create="0" delete="1" default_order="class_group_id">
                <field name="name"/>
                <field name="class_group_id" optional="show"/>
                <field name="city" optional="show"/>
                <field name="company_id" optional="show"/>
                <field name="location_id" optional="show"/>
                <field name="trainer_id" optional="show"/>
                <field name="class_program_id" optional="show"/>
                <field name="start_training" optional="show"/>
                <field name="end_training" optional="show"/>
                <field name="children_ids" widget="many2many_tags" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="class_training_view_form" model="ir.ui.view">
        <field name="name">class.training.view.form</field>
        <field name="model">class.training</field>
        <field name="arch" type="xml">
            <form string="Trainings" create="0" delete="0">
                <header>
                    <button name="completed_training" type="object" string="Completed training" class="btn btn-success"
                            invisible="state == 'completed'" help="After Completed training you can not update record"/>
                    <field name="state" widget="statusbar" statusbar_visible="planed,completed"/>  <!--options="{'clickable': '1'}"-->
                </header>
                <sheet>
                    <group>
                        <group class="o_label_nowrap">
                            <field name="name" readonly="state == 'completed'"/>
                            <field name="class_group_id" readonly="1"/>
                            <field name="color" widget="color" invisible="1"/>

                            <field name="date_training" invisible="1"/>
                            <field name="time_training" widget="float_time" invisible="1"/>
                            <field name="duration_training" widget="float_time" readonly="state == 'completed'"/>

                            <field name="start_training" widget="daterange" options="{'end_date_field': 'end_training'}"/>
                            <field name="end_training" invisible="1"/>

                            <field name="trainer_id" widget="many2one_avatar_user" readonly="state == 'completed'"/>
                        </group>
                        <group>
                            <field name="class_program_id" readonly="1"/>
                            <field name="location_id" readonly="state == 'completed'"/>
                            <field name="city" readonly="1"/>
                            <field name="company_id" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="children_ids" widget="one2many">
                            <tree string="Children" editable="bottom">
                                <field name="state" column_invisible="1"/>

                                <field name="child_id"/>
                                <field name="on_training" readonly="state == 'completed' or subscription_frozen"/>
                                <field name="working_off" readonly="state == 'completed' or subscription_frozen"/>
                                <field name="trial_training" readonly="1"/>
                                <field name="subscription_frozen" readonly="1"/>
                            </tree>
                        </field>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="class_training_view_calendar" model="ir.ui.view">
        <field name="name">class.training.view.calendar</field>
        <field name="model">class.training</field>
        <field name="arch" type="xml">
            <calendar string="Trainings" create="0" delete="0" quick_create="0" mode="month"
                      date_start="start_training" date_stop="end_training" color="color"
                      hide_time="false" event_limit="5" event_open_popup="true"
                      date_delay="duration_training">

                <field name="class_group_id" filters="1"/>
                <field name="name"/>
                <field name="trainer_id" widget="many2one_avatar_user" filters="1"/>
                <field name="class_program_id" filters="1"/>
                <field name="start_training"/>
                <field name="end_training"/>
            </calendar>
        </field>
    </record>

    <record id="class_training_kanban" model="ir.ui.view">
        <field name="name">class.training.kanban</field>
        <field name="model">class.training</field>
        <field name="arch" type="xml">
            <kanban sample="1" default_order="create_date" default_group_by="class_group_id" create="0" delete="0">
                <field name="display_name"/>
                <field name="class_group_id"/>
                <field name="start_training"/>
                <field name="end_training"/>
                <field name="duration_training"/>
                <field name="trainer_id"/>
                <field name="class_program_id"/>
                <field name="city"/>
                <field name="location_id"/>
                <field name="color"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_card shadow-sm" style="border-radius: 10px; overflow: hidden;">
                            <div class="o_kanban_card_header p-3 text-white"
                                 t-att-style="'background-color: ' + record.color.raw_value">
                                <strong class="o_kanban_record_title d-block">
                                    <field name="display_name"/>
                                </strong>
                            </div>
                            <div class="o_kanban_card_body p-3 bg-light">
                                <div class="mb-2 d-flex align-items-center">
                                    <i class="fa fa-file-text-o me-2 text-secondary" aria-hidden="true"></i>
                                    <span class="text-muted">Group:</span>
                                    <span class="ms-2 fw-bold">
                                        <field name="class_group_id"/>
                                    </span>
                                </div>
                                <div class="mb-2 d-flex align-items-center">
                                    <i class="fa fa-clock-o me-2 text-secondary" aria-hidden="true"></i>
                                    <span class="text-muted">Start training:</span>
                                    <span class="ms-2 fw-bold">
                                        <field name="start_training"/>
                                    </span>
                                </div>
                                <div class="mb-2 d-flex align-items-center">
                                    <i class="fa fa-clock-o me-2 text-secondary" aria-hidden="true"></i>
                                    <span class="text-muted">End training:</span>
                                    <span class="ms-2 fw-bold">
                                        <field name="end_training"/>
                                    </span>
                                </div>
                                <div class="mb-2 d-flex align-items-center">
                                    <i class="fa fa-clock-o me-2 text-secondary" aria-hidden="true"></i>
                                    <span class="text-muted">Duration training:</span>
                                    <span class="ms-2 fw-bold">
                                        <field name="duration_training" widget="float_time"/>
                                    </span>
                                </div>
                                <div class="mb-2 d-flex align-items-center">
                                    <i class="fa fa-user me-2 text-secondary" aria-hidden="true"></i>
                                    <span class="text-muted">Trainer:</span>
                                    <span class="ms-2 fw-bold">
                                        <field name="trainer_id"/>
                                    </span>
                                </div>
                                <div class="mb-2 d-flex align-items-center">
                                    <i class="fa fa-file-text-o me-2 text-secondary" aria-hidden="true"></i>
                                    <span class="text-muted">Program:</span>
                                    <span class="ms-2 fw-bold">
                                        <field name="class_program_id"/>
                                    </span>
                                </div>
                                <div class="mb-2 d-flex align-items-center">
                                    <i class="fa fa-map-marker me-2 text-secondary" aria-hidden="true"></i>
                                    <span class="text-muted">City:</span>
                                    <span class="ms-2 fw-bold">
                                        <field name="city"/>
                                    </span>
                                </div>
                                <div class="mb-2 d-flex align-items-center">
                                    <i class="fa fa-location-arrow me-2 text-secondary" aria-hidden="true"></i>
                                    <span class="text-muted">Location:</span>
                                    <span class="ms-2 fw-bold">
                                        <field name="location_id"/>
                                    </span>
                                </div>
                            </div>
<!--                            <div class="o_kanban_card_footer p-2 text-end text-muted">-->
<!--                                <span>-->
<!--                                    Created on: <field name="create_date"/>-->
<!--                                </span>-->
<!--                            </div>-->
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="class_training_search" model="ir.ui.view">
        <field name="name">class.training.search</field>
        <field name="model">class.training</field>
        <field name="arch" type="xml">
            <search string="Trainings">
                <field name="name"/>
                <field name="class_group_id"/>
                <field name="class_program_id"/>
                <field name="trainer_id"/>
                <field name="city"/>
                <field name="location_id"/>
                <field name="children_ids" operator="child_of" string="Children"
                       filter_domain="[('children_ids.child_id.name', 'ilike', self)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_class_group_id" string="Group" domain="[]" context="{'group_by':'class_group_id'}"/>
                    <filter name="group_class_program_id" string="Program" domain="[]" context="{'group_by':'class_program_id'}"/>
                    <filter name="group_trainer_id" string="Trainer" domain="[]" context="{'group_by':'trainer_id'}"/>
                    <filter name="group_city" string="City" domain="[]" context="{'group_by':'city'}"/>
                    <filter name="group_location_id" string="Location" domain="[]" context="{'group_by':'location_id'}"/>
                    <filter name="group_start_training" string="Start training" domain="[]" context="{'group_by':'start_training'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_class_training" model="ir.actions.act_window">
        <field name="name">Trainings</field>
        <field name="res_model">class.training</field>
        <field name="view_mode">kanban,tree,form,calendar</field>
    </record>

    <menuitem
        id="menu_class_training"
        name="Trainings"
        action="action_class_training"
        parent="root_menu_footbik"
        sequence="1"
    />

</odoo>
