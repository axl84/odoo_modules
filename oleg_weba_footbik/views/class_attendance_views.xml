<odoo>

    <record id="class_attendance_view_tree" model="ir.ui.view">
        <field name="name">class.attendance.view.tree</field>
        <field name="model">class.attendance</field>
        <field name="arch" type="xml">
            <tree string="Attendance" default_order="class_training_id" create="0" delete="0">
                <field name="class_training_id" optional="show"/>
                <field name="child_id" optional="show"/>
                <field name="start_training" optional="show"/>
                <field name="end_training" optional="show"/>
                <field name="company_id" optional="show"/>
                <field name="state" optional="show"/>
                <field name="on_training" optional="show"/>
                <field name="working_off" optional="show"/>
                <field name="trial_training" optional="show"/>
                <field name="subscription_frozen" optional="show"/>
            </tree>
        </field>
    </record>

    <record id="class_attendance_view_form" model="ir.ui.view">
        <field name="name">class.attendance.view.form</field>
        <field name="model">class.attendance</field>
        <field name="arch" type="xml">
            <form string="Attendance" create="0" delete="0">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="planed,completed"/>  <!--options="{'clickable': '1'}"-->
                </header>
                <sheet>
                    <group>
                        <group class="o_label_nowrap">
                            <field name="class_training_id" readonly="1"/>
                            <field name="child_id" widget="many2one_avatar_user" readonly="1"/>

                            <field name="start_training" widget="daterange" options="{'end_date_field': 'end_training'}" readonly="1"/>
                            <field name="end_training" invisible="1"/>

                            <field name="duration_training" widget="float_time" readonly="1"/>
                            <field name="company_id" readonly="1"/>
                            <field name="color" widget="color" invisible="1"/>
                        </group>
                        <group>
                            <field name="on_training" readonly="state == 'completed' or subscription_frozen"/>
                            <field name="working_off" readonly="state == 'completed' or subscription_frozen"/>
                            <field name="trial_training" readonly="1"/>
                            <field name="subscription_frozen" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="class_attendance_view_calendar" model="ir.ui.view">
        <field name="name">class.attendance.view.calendar</field>
        <field name="model">class.attendance</field>
        <field name="arch" type="xml">
            <calendar string="Attendance" create="0" delete="0" quick_create="0" mode="month"
                      date_start="start_training" date_stop="end_training" color="color"
                      hide_time="false" event_limit="5" event_open_popup="true"
                      date_delay="duration_training">

                <field name="class_training_id" filters="1"/>
                <field name="child_id" widget="many2one_avatar_user" filters="1"/>
                <field name="start_training"/>
                <field name="end_training"/>
            </calendar>
        </field>
    </record>

    <record id="class_attendance_kanban" model="ir.ui.view">
        <field name="name">class.attendance.kanban</field>
        <field name="model">class.attendance</field>
        <field name="arch" type="xml">
            <kanban sample="1" default_order="class_training_id" default_group_by="child_id" create="0" delete="0">
                <field name="display_name"/>
                <field name="child_id"/>
                <field name="class_training_id"/>
                <field name="start_training"/>
                <field name="end_training"/>
                <field name="duration_training"/>
                <field name="on_training"/>
                <field name="working_off"/>
                <field name="trial_training"/>
                <field name="subscription_frozen"/>
                <field name="color"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_card shadow-sm" style="border-radius: 10px; overflow: hidden;">
                            <div class="o_kanban_card_header p-3 text-white"
                                 t-att-style="'background-color: ' + record.color.raw_value">
                                <strong class="o_kanban_record_title d-block">
                                    <field name="display_name"/>
                                </strong>
                            </div>
                            <div class="o_kanban_card_body p-3 bg-light">
                                <div class="mb-2 d-flex align-items-center">
                                    <i class="fa fa-file-text-o me-2 text-secondary" aria-hidden="true"></i>
                                    <span class="text-muted">Child:</span>
                                    <span class="ms-2 fw-bold">
                                        <field name="child_id"/>
                                    </span>
                                </div>
                                <div class="mb-2 d-flex align-items-center">
                                    <i class="fa fa-file-text-o me-2 text-secondary" aria-hidden="true"></i>
                                    <span class="text-muted">Training:</span>
                                    <span class="ms-2 fw-bold">
                                        <field name="class_training_id"/>
                                    </span>
                                </div>
                                <div class="mb-2 d-flex align-items-center">
                                    <i class="fa fa-clock-o me-2 text-secondary" aria-hidden="true"></i>
                                    <span class="text-muted">Start training:</span>
                                    <span class="ms-2 fw-bold">
                                        <field name="start_training"/>
                                    </span>
                                </div>
                                <div class="mb-2 d-flex align-items-center">
                                    <i class="fa fa-clock-o me-2 text-secondary" aria-hidden="true"></i>
                                    <span class="text-muted">End training:</span>
                                    <span class="ms-2 fw-bold">
                                        <field name="end_training"/>
                                    </span>
                                </div>
                                <div class="mb-2 d-flex align-items-center">
                                    <i class="fa fa-clock-o me-2 text-secondary" aria-hidden="true"></i>
                                    <span class="text-muted">Duration training:</span>
                                    <span class="ms-2 fw-bold">
                                        <field name="duration_training" widget="float_time"/>
                                    </span>
                                </div>
                                <div class="mb-2 d-flex align-items-center">
                                    <i class="fa fa-edit me-2 text-secondary" aria-hidden="true"></i>
                                    <span class="text-muted">On training:</span>
                                    <span class="ms-2 fw-bold">
                                        <field name="on_training"/>
                                    </span>

                                    <i class="fa fa-crosshairs me-2 text-secondary" aria-hidden="true"></i>
                                    <span class="text-muted">Working off:</span>
                                    <span class="ms-2 fw-bold">
                                        <field name="working_off"/>
                                    </span>
                                </div>
                                <div class="mb-2 d-flex align-items-center">
                                    <i class="fa fa-eye me-2 text-secondary" aria-hidden="true"></i>
                                    <span class="text-muted">Trial training:</span>
                                    <span class="ms-2 fw-bold">
                                        <field name="trial_training"/>
                                    </span>

                                    <i class="fa fa-times me-2 text-secondary" aria-hidden="true"></i>
                                    <span class="text-muted">Sub. frozen:</span>
                                    <span class="ms-2 fw-bold">
                                        <field name="subscription_frozen"/>
                                    </span>
                                </div>

                            </div>
<!--                            <div class="o_kanban_card_footer p-2 text-end text-muted">-->
<!--                                <span>-->
<!--                                    Created on: <field name="create_date"/>-->
<!--                                </span>-->
<!--                            </div>-->
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="class_attendance_search" model="ir.ui.view">
        <field name="name">class.attendance.search</field>
        <field name="model">class.attendance</field>
        <field name="arch" type="xml">
            <search string="Attendance">
                <field name="child_id"/>
                <field name="class_training_id"/>
                <separator/>
                <filter name="on_training" string="On training" domain="[('on_training', '=', True)]"/>
                <filter name="working_off" string="Working off" domain="[('working_off', '=', True)]"/>
                <filter name="trial_training" string="Trial training" domain="[('trial_training', '=', True)]"/>
                <filter name="subscription_frozen" string="Subscription frozen" domain="[('subscription_frozen', '=', True)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_class_training_id" string="Training class" domain="[]" context="{'group_by':'class_training_id'}"/>
                    <filter name="group_child_id" string="Child" domain="[]" context="{'group_by':'child_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_class_attendance" model="ir.actions.act_window">
        <field name="name">Attendance</field>
        <field name="res_model">class.attendance</field>
        <field name="view_mode">kanban,tree,form,calendar</field>
    </record>

    <menuitem
        id="menu_class_attendance"
        name="Attendance"
        action="action_class_attendance"
        parent="root_menu_footbik"
        sequence="2"
    />

</odoo>
