<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="chat_bot_partner_send_wizard_menu" model="ir.ui.view">
        <field name="name">chat.bot.partner.send.wizard.form</field>
        <field name="model">chat.bot.partner.send</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="partner_id" readonly="1"/>
                    <field domain="[('id', 'in', sender_ids)]" name="sender_id"/>
                    <field domain="[('id', 'in', conversation_ids)]" name="conversation_id" readonly="sender_id == False"/>
                    <field name="text" required="1" string="Message"/>
                    <field invisible="1" name="name"/>
                    <field invisible="1" name="chat_id"/>
                    <field invisible="1" name="sender_ids"/>
                    <field invisible="1" name="conversation_ids"/>
                </group>
                <footer>
                    <button class="oe_highlight" name="action_send" string="Send" type="object"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form></field>
    </record>
    <record id="chat_bot_partner_send_wizard_tree_menu" model="ir.ui.view">
        <field name="name">chat.bot.partner.send.wizard.tree</field>
        <field name="model">chat.bot.partner.send.mass</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field invisible="1" name="kw_partner_ids"/>
                    <field invisible="0" name="chat_id" required="1"/>
                    <field name="text" required="1" string="Message"/>
                    <field invisible="1" name="name"/>
                    <field invisible="1" name="conversation_ids"/>
                </group>
                <footer>
                    <button class="oe_highlight" name="action_send" string="Send" type="object"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form></field>
    </record>
    <record id="chat_bot_partner_send_wizard" model="ir.actions.act_window">
        <field name="name">ChatBot Send</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">chat.bot.partner.send</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_res_partner"/>
        <field name="binding_view_types">form</field>
        <field name="view_mode">form</field>
        <field name="context">{'default_partner_id': active_id}</field>
    </record>
    <record id="chat_bot_partner_send_tree_wizard" model="ir.actions.act_window">
        <field name="name">ChatBot Send</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">chat.bot.partner.send.mass</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_res_partner"/>
        <field name="binding_view_types">list</field>
        <field name="view_mode">form</field>
        <field name="context">{'default_kw_partner_ids': active_ids}</field>
    </record>
</odoo>
