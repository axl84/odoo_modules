<odoo noupdate="0">
    <record id="kw_chatbot_messenger_telegram" model="kw.chatbot.messenger">
        <field name="name">Telegram</field>
        <field name="sequence">200</field>
        <field name="provider">telegram</field>
        <field name="image_128" type="base64"
               file="kw_chatbot/static/src/img/telegram_logo.png"/>
        <field name="module_name">kw_chatbot_telegram</field>
        <field name="description" type="html">
            <p>
                <a href="https://telegram.org/">Telegram</a>
                — is a cloud-based mobile and desktop messaging app with a
                focus on security and speed.
            </p>
        </field>
    </record>

