<odoo noupdate="1">
    <record id="module_category_kw_chatbot" model="ir.module.category">
        <field name="name">Chat Bot</field>
        <field name="sequence">30</field>
    </record>
    <record id="group_kw_chatbot_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id"
               ref="kw_chatbot.module_category_kw_chatbot"/>
    </record>
    <record id="group_kw_chatbot_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id"
               ref="kw_chatbot.module_category_kw_chatbot"/>
        <field name="implied_ids"
               eval="[(4, ref('kw_chatbot.group_kw_chatbot_user')),]"/>
    </record>

    <record id="kw_chatbot_chat_rule_multi_company" model="ir.rule">
        <field name="name">Chatbot Chat</field>
        <field name="model_id" ref="model_kw_chatbot_chat"/>
        <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
    </record>

    <record id="kw_chatbot_conversation_rule_multi_company" model="ir.rule">
        <field name="name">Chatbot Conversation</field>
        <field name="model_id" ref="model_kw_chatbot_conversation"/>
        <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
    </record>

    <record id="kw_chatbot_dialog_rule_multi_company" model="ir.rule">
        <field name="name">Chatbot Dialog</field>
        <field name="model_id" ref="model_kw_chatbot_dialog"/>
        <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
    </record>



    <record id="group_kw_chatbot_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="category_id"
               ref="kw_chatbot.module_category_kw_chatbot"/>
        <field name="implied_ids"
               eval="[(4, ref('kw_chatbot.group_kw_chatbot_manager')),]"/>
        <field name="users"
               eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

</odoo>
