<odoo>
    <record id="kw_chatbot_kw_chatbot_conversation_form" model="ir.ui.view">
        <field name="name">kw.chatbot.conversation.form (kw_chatbot)</field>
        <field name="model">kw.chatbot.conversation</field>
        <field name="arch" type="xml">
            <form>
                <header/>
                <sheet>
                    <div name="button_box" class="oe_button_box"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="sender_id"/>
                            <field name="partner_id" invisible="0"/>
                            <field name="user_id"/>
                            <field name="is_closed"/>
                            <field name="last_activity_datetime"/>
                        </group>
                        <group>
                            <field name="chat_id"/>
                            <field name="dialog_id"/>
                            <field name="operator_live_id" string="Operator Odoo" invisible="1"/>
                            <field name="is_personal" invisible="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Messages">
                            <field name="chatbot_message_ids">
                                <tree editable="bottom">
                                    <field name="conversation_id"
                                           invisible="1"/>
                                    <field name="text"/>
                                    <field name="sender_id"/>
                                    <field name="name"/>
                                    <field name="is_bot_message" invisible="1"/>
                                    <field name="is_dialog_message" invisible="1"/>
                                    <field name="is_call_back_message" invisible="1"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Question - Answer">
                            <field name="question_ids">
                                <tree editable="bottom">
                                    <field name="conversation_id"
                                           invisible="1"/>
                                    <field name="question"/>
                                    <field name="answer"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Messages Test">
                            <field name="chat_history" widget="html" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
                <field name="active" invisible="1"/>
            </form>
        </field>
    </record>

    <record id="kw_chatbot_kw_chatbot_conversation_tree" model="ir.ui.view">
        <field name="name">kw.chatbot.conversation.tree (kw_chatbot)</field>
        <field name="model">kw.chatbot.conversation</field>
        <field name="arch" type="xml">
            <tree create="0" delete="0">
                <field name="name"/>
                <field name="sender_id"/>
                <field name="partner_id"/>
                <field name="is_closed"/>
                <field name="last_activity_datetime"/>
                <field name="chat_id"/>
                <field name="dialog_id"/>
                <button name="livechat_open_and_subscribe_button" type="object" string="LiveChat" class="oe_highlight"/>
            </tree>
        </field>
    </record>

    <record id="kw_chatbot_kw_chatbot_conversation_action_window"
            model="ir.actions.act_window">
        <field name="name">Conversations</field>
        <field name="res_model">kw.chatbot.conversation</field>
        <field name='view_mode'>tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new chatbot conversation
            </p>
        </field>
    </record>

    <menuitem id="kw_chatbot_kw_chatbot_conversation_menu"
              action="kw_chatbot_kw_chatbot_conversation_action_window"
              parent="kw_chatbot_main_menu"
              name="Conversations" sequence="300"/>
</odoo>
