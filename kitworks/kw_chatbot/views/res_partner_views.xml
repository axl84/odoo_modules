<?xml version="1.0"?>
<odoo>
    <record id="view_partner_form_inherit_website" model="ir.ui.view">
        <field name="name">res.partner.form.website.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
<!--        <field name="groups_id" eval="[(4, ref('kw_chatbot.group_kw_chatbot_admin'))]"/>-->
        <field name="arch" type="xml">
<!--            <xpath expr="//div[@name='button_box']" position="inside">-->
<!--                <button name="conversation_action_button" string="Conversation"-->
<!--                        type="object" class="oe_stat_button"-->
<!--                        icon="fa-users">-->
<!--                </button>-->
<!--            </xpath>-->
            <xpath expr="//field[@name='title']" position="after">
                <field name="is_livechat_bot" groups="base.group_no_one"/>
                <field name="conversation_ids" invisible="1"/>
            </xpath>
            <notebook position="inside">
                <page string="Conversation">

                        <field name="conversation_ids" nolabel="1">
                            <tree>
                                <field name="name"/>
                                <field name="sender_id"/>
                                <field name="is_closed"/>
                                <field name="last_activity_datetime"/>
                                <field name="chat_id"/>
                                <field name="dialog_id"/>
                                <button name="livechat_open_and_subscribe_button" type="object" string="LiveChat" class="oe_highlight"/>
                            </tree>
                        </field>

                </page>
<!--                <page string="Chat Bot Sender">-->
<!--                    <group>-->
<!--                        <field name="sender_ids"/>-->
<!--                    </group>-->
<!--                </page>-->
<!--                <page name="consult" string="Consult" groups="base.group_no_one">-->
<!--                    <group>-->
<!--                        <field name="kw_is_consultant" readonly="1"/>-->
<!--                        <field name="kw_is_available_consultant" widget="boolean_toggle"-->
<!--                               attrs="{'invisible': [('kw_is_consultant','=',False)]}"/>-->
<!--                    </group>-->
<!--                </page>-->
            </notebook>
        </field>
    </record>

    <record model="ir.ui.view" id="kw_chatbot_res_partner_kanban_view">
        <field name="name">res.partner.kanban (kw_chatbot)</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.res_partner_kanban_view"/>
<!--        <field name="groups_id" eval="[(4, ref('kw_chatbot.group_kw_chatbot_admin'))]"/>-->
        <field name="arch" type="xml">
            <xpath expr="//kanban" position="inside">
                <field name="conversation_ids"/>
            </xpath>
        </field>
    </record>

</odoo>
