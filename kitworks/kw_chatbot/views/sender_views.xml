<odoo>
    <record id="kw_chatbot_chat_bot_send_sender_action_window"
            model="ir.actions.act_window">
        <field name="type">ir.actions.act_window</field>
        <field name="name">Send Message</field>
        <field name="res_model">chat.bot.send</field>
        <field name='view_mode'>form</field>
        <field name="target">new</field>
        <field name="binding_view_types">form</field>
    </record>

    <record id="kw_chatbot_kw_chatbot_sender_form" model="ir.ui.view">
        <field name="name">kw.chatbot.sender.form (kw_chatbot)</field>
        <field name="model">kw.chatbot.sender</field>
        <field name="arch" type="xml">
            <form>
                <header/>
                <sheet>
                    <div name="button_box" class="oe_button_box"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="messenger_id"/>
                            <field name="partner_id"/>
                            <field name="aproved_consultant"/>
                            <field name="user_id"/>
                            <field name="is_ready_for_consult" readonly="0"/>
                            <field name="sequence" invisible="1"/>
                        </group>
                        <group/>
                    </group>
                    <notebook>
                        <page string="Conversation">
                            <field name="conversation_ids"/>
                        </page>
                    </notebook>
                </sheet>
                <field name="active" invisible="1"/>
                <field name="provider" invisible="1"/>
            </form>
        </field>
    </record>

    <record id="kw_chatbot_kw_chatbot_sender_tree" model="ir.ui.view">
        <field name="name">kw.chatbot.sender.tree (kw_chatbot)</field>
        <field name="model">kw.chatbot.sender</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="messenger_id"/>
                <field name="user_id"/>
                <field name="is_ready_for_consult"/>
            </tree>
        </field>
    </record>

    <record id="kw_chatbot_kw_chatbot_sender_action_window"
            model="ir.actions.act_window">
        <field name="name">Senders</field>
        <field name="res_model">kw.chatbot.sender</field>
        <field name='view_mode'>tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new chatbot sender
            </p>
        </field>
    </record>

    <menuitem id="kw_chatbot_kw_chatbot_sender_menu"
              action="kw_chatbot_kw_chatbot_sender_action_window"
              parent="kw_chatbot_main_menu"
              name="Senders" sequence="900"/>
</odoo>
