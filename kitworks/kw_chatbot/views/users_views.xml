<odoo>
    <record id="kw_chatbot_communicate_res_users_form" model="ir.ui.view">
        <field name="name">res.users.form (kw_chatbot)</field>
        <field name="model">res.users</field>
        <field name="inherit_id"
               ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Chatbot">
                    <group>
                        <group>
                            <field name="is_chatbot_consultant"/>
                        </group>
                    </group>
                </page>
            </notebook>
        </field>
    </record>
</odoo>
