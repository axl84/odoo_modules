<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="kw_chatbot_crm_lead_view_form" model="ir.ui.view">
        <field name="name">crm.lead.form (kw_chatbot)</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <!--        <field name="groups_id" eval="[(4, ref('kw_chatbot.group_kw_chatbot_admin'))]"/>-->
        <field name="arch" type="xml">
            <xpath expr="//field[@name='team_id']" position="after">
                <field invisible="1" name="kw_conversation_id"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" icon="fa-comment" invisible="kw_conversation_id == False" name="livechat_open_and_subscribe_button" string="LiveChat" type="object">
                </button>
            </xpath></field>
    </record>
</odoo>
