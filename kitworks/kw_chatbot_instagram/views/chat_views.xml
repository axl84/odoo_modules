<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="kw_chatbot_instagram_kw_chatbot_chat_form" model="ir.ui.view">
        <field name="name">kw.chatbot.chat.form (kw_chatbot_instagram)</field>
        <field name="model">kw.chatbot.chat</field>
        <field name="inherit_id" ref="kw_chatbot.kw_chatbot_kw_chatbot_chat_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='messenger_id']" position="after">
                <!--                <field name="is_instagram_developer_mode" attrs="{'invisible':[('provider','!=','instagram')]}" groups="base.group_no_one"/>-->
                <field invisible="provider != 'instagram'" name="is_instagram_developer_mode"/>
                <field invisible="is_instagram_developer_mode != True" name="is_instagram_login"/>
            </xpath>
            <notebook position="inside">
                <page invisible="is_instagram_login == True or provider != 'instagram'" string="Instagram">
                    <button class="btn btn-primary" name="instagram_copy_url_button" string="Update url" type="object"/>
                    <button class="btn btn-primary" name="set_instagram_verify_token" string="Update token" type="object"/>
                    <group>
                        <field name="instagram_access_token" required="(provider == 'instagram' and is_instagram_login != True)"/>
                        <field name="instagram_account_id" required="(provider == 'instagram' and is_instagram_login != True)"/>
                        <field name="facebook_page_account_id" required="(provider == 'instagram' and is_instagram_login != True)"/>
                        <field name="instagram_copy_url"/>
                        <field name="instagram_verify_token"/>
                        <field name="instagram_webhook_token"/>
                        <field groups="base.group_no_one" name="instagram_developer_url"/>
                    </group>
                </page>
            </notebook></field>
    </record>
</odoo>
