<odoo>

    <record id="chat_send_wa_template_wizard_form" model="ir.ui.view">
        <field name="name">send.wa.template.wizard.form</field>
        <field name="model">send.wa.template.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="template_id" readonly="1"/>
                    <field name="conversation_ids" widget="many2many_tags"/>
                </group>
                <footer>
                    <button name="action_send" string="Send" type="object"
                            class="oe_highlight"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
