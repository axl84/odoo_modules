<odoo noupdate="1">
    <record forcecreate="True" id="kw_chatbot_whatsapp_ir_cron_update_whatsapp_token_action" model="ir.cron">
        <field name="name">Update WhatsApp Token</field>
        <field name="model_id" ref="model_kw_chatbot_chat"/>
        <field name="state">code</field>
        <field name="code">model._get_whatsapp_long_lived_token()</field>
        <field name="interval_number">7</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
    </record>
</odoo>
