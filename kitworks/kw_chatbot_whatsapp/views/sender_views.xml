<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="kw_chatbot_whatsapp_kw_chatbot_sender_form" model="ir.ui.view">
        <field name="name">kw.chatbot.sender.form (kw_chatbot_whatsapp)</field>
        <field name="model">kw.chatbot.sender</field>
        <field name="inherit_id" ref="kw_chatbot.kw_chatbot_kw_chatbot_sender_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page invisible="provider != 'whatsapp'" string="WhatsApp">
                    <group>
                        <field name="whatsapp_name"/>
                        <field name="whatsapp_id"/>
                    </group>
                </page>
            </notebook></field>
    </record>
    <record id="kw_chatbot_whatsapp_kw_chatbot_sender_search" model="ir.ui.view">
        <field name="name">kw.chatbot.sender.form (kw_chatbot_whatsapp)</field>
        <field name="model">kw.chatbot.sender</field>
        <field eval="8" name="priority"/>
        <field name="arch" type="xml">
            <search>
                <field filter_domain="[('whatsapp_name','ilike',self)]" name="whatsapp_name"/>
            </search></field>
    </record>
</odoo>
