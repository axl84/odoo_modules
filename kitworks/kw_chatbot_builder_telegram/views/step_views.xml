<odoo>
    <record id="kw_chatbot_telegram_kw_chatbot_step_form" model="ir.ui.view">
        <field name="name">kw.chatbot.step.form (kw_chatbot_telegram)</field>
        <field name="model">kw.chatbot.step</field>
        <field name="inherit_id"
               ref="kw_chatbot_builder.kw_chatbot_builder_kw_chatbot_step_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Telegram Keyboard" groups="base.group_no_one">
                    <field name="telegram_keyboard_ids">
                        <tree>
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                        </tree>
                    </field>
                </page>
                <page string="Telegram Buttons" groups="base.group_no_one">
                    <field name="telegram_button_ids"/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
