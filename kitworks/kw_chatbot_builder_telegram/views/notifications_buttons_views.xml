<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="kw_chatbot_builder_telegram_kw_chatbot_step_form" model="ir.ui.view">
        <field name="name">kw.chatbot.notification.form (kw_chatbot_builder_telegram)</field>
        <field name="model">kw.chatbot.notification</field>
        <field name="inherit_id" ref="kw_chatbot.kw_chatbot_notification_kw_chatbot_notification_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='trigger']" position="after">
                <field domain="[('model_id', '=', model_id)]" name="sorted_field_id"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Telegram Buttons">
                    <group>
                        <group>
                            <field name="is_save_button_activity" widget="boolean_toggle"/>
                            <field domain="[('model_id', '=', model_id), ('ttype', 'in', ['many2one'])]" invisible="is_save_button_activity == False" name="related_fields_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <field name="telegram_button_ids"><tree>
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="active"/>
                            <field name="step_id"/>
                            <field name="callback_data"/>
                            <field invisible="1" name="notification_id"/>
                            <field name="fields_lines"></field>
                        </tree></field>
                </page>
                <page string="Template not found Records">
                    <field name="message_not_found"/>
                </page>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page name="telegram filtered fields" string="Telegram Filtered Fields">
                    <group>
                        <group>
                            <field name="is_days_filter"/>
                            <field name="is_unique_by_field"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field domain="[('model_id', '=', model_id)]" invisible="is_unique_by_field == False" name="unique_filter_field_id" required="is_unique_by_field == True"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <group>
                                <field domain="[('model_id', '=', model_id),('ttype','in',['date', 'datetime', 'integer'])]" invisible="is_days_filter == False" name="filter_field_id" required="is_days_filter == True"/>
                            </group>
                            <group>
                                <field invisible="is_days_filter == False" name="filter_type" required="is_days_filter == True"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <field invisible="is_days_filter == False" name="value_type" required="is_days_filter == True"/>
                            </group>
                            <group>
                                <field invisible="is_days_filter == False" name="filter_value" required="is_days_filter == True"/>
                            </group>
                        </group>
                    </group>
                    <field context="{'default_model_id': model_id}" name="filtered_fields_ids">
                        <tree editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field force_save="1" name="model_id" readonly="True"/>
                            <field name="field_id" required="filtered_type != 'own_model'" readonly="filtered_type == 'own_model'"/>
                            <field name="filtered_type"/>
                            <field name="partner_field_ids" invisible="1"/>
                            <field domain="[('id','in',partner_field_ids)]" name="partner_field_id" readonly="filtered_type in ['conversation', 'own_model']"/>
                        </tree></field>?
                </page>
            </xpath></field>
    </record>
</odoo>
