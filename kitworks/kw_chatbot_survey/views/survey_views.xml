<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="kw_chatbot_survey_survey_view_form" model="ir.ui.view">
        <field name="name">survey.survey.form (kw_chatbot_survey)</field>
        <field name="model">survey.survey</field>
        <field name="inherit_id" ref="survey.survey_survey_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='options']/group[@name='options']" position="inside">
                <group name="kw_chatbot_survey" string="Chatbot">
                    <field name="message_start_survey"/>
                    <field name="message_end_survey"/>
                    <field name="kw_message_error"/>
                    <field name="kw_close_quiz_button_name"/>
                </group>
            </xpath>
            <notebook position="inside">
                <page invisible="kw_is_entity_creator == False" string="Default fields">
                    <field name="kw_default_value_ids"><tree editable="bottom">
                            <field invisible="1" name="survey_id"/>
                            <field invisible="1" name="kw_model_id"/>
                            <field name="col1" options="{'no_create': True}"/>
                            <field name="evaluation_type"/>
                            <field name="resource_ref" options="{'hide_model': True, 'no_create': True}" readonly="evaluation_type != 'reference'"/>
                            <field force_save="1" name="value" options="{'no_create': True}" readonly="evaluation_type in ['reference', 'partner']"/>
                        </tree></field>
                </page>
            </notebook></field>
    </record>
    <record id="kw_chatbot_survey_telegram_survey_user_input_form" model="ir.ui.view">
        <field name="name">survey.user_input.form (kw_chatbot_survey_telegram)</field>
        <field name="model">survey.user_input</field>
        <field name="inherit_id" ref="survey.survey_user_input_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group/group[2]" position="inside">
                <field name="kw_chatbot_partner_id"/>
            </xpath></field>
    </record>
    <record id="kw_chatbot_survey_telegram_survey_question_form" model="ir.ui.view">
        <field name="name">survey.question.form (kw_chatbot_survey_telegram)</field>
        <field name="model">survey.question</field>
        <field name="inherit_id" ref="kw_survey_create_entity.kw_survey_create_entity_survey_question_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='kw_entity_field_id']" position="after">
                <field invisible="kw_search_model_id == False" name="is_search"/>
                <field invisible="is_search != True" name="is_update_suggested_answer"/>
                <field invisible="is_search != True" name="kw_search_model_id"/>
                <field invisible="is_search != True" name="kw_field_waiting_message"/>
                <field domain="[('model_id','=',kw_search_model_id)]" invisible="is_search != True" name="kw_search_field_id" required="is_search == True"/>
                <field invisible="is_search != True" name="kw_field_search_message"/>
                <field invisible="is_search != True" name="kw_search_message"/>
                <field invisible="is_search != True" name="kw_button_search_message"/>
                <field invisible="is_search != True" name="kw_button_action_message"/>
                <field invisible="is_search != True" name="code" options="{'mode': 'python'}" placeholder="Enter Python code here. Help about Python expression is available in the help tab of this document." widget="ace"/>
            </xpath></field>
    </record>
</odoo>
