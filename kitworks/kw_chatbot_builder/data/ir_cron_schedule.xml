<odoo noupdate="1">


    <record forcecreate="True" id="ir_cron_run_step" model="ir.cron">
        <field name="name">Run chatbot step</field>
        <field name="model_id" ref="model_kw_chatbot_step"/>
        <field name="state">code</field>
        <field name="code">model.schedule_step()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="numbercall">-1</field>
        <field eval="False" name="doall"/>
    </record>

    <record forcecreate="True" id="ir_cron_send_msg" model="ir.cron">
        <field name="name">Send chatbot message</field>
        <field name="model_id" ref="model_kw_chatbot_dialog"/>
        <field name="state">code</field>
        <field name="code">model.send_thank_you_messages()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="numbercall">-1</field>
        <field eval="False" name="doall"/>
    </record>


</odoo>
