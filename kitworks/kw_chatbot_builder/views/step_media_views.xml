<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="kw_chatbot_builder_kw_chatbot_step_media_form" model="ir.ui.view">
        <field name="name">kw.chatbot.step.media.form (kw_chatbot_builder)</field>
        <field name="model">kw.chatbot.step.media</field>
        <field name="arch" type="xml">
            <form>
                <header/>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="step_id"/>
                            <field name="media_type"/>
                        </group>
                        <group>
                            <field name="dialog_id"/>
                            <field invisible="media_type == 'video'" name="image_file" required="media_type == 'image'"/>
                            <field invisible="media_type == 'image'" name="media_file" required="media_type == 'video'"/>
                        </group>
                    </group>
                    <notebook/>
                </sheet>
                <field invisible="1" name="active"/>
            </form></field>
    </record>
    <record id="kw_chatbot_builder_kw_chatbot_step_media_tree" model="ir.ui.view">
        <field name="name">kw.chatbot.step.media.tree (kw_chatbot_builder)</field>
        <field name="model">kw.chatbot.step.media</field>
        <field name="arch" type="xml">
            <tree editable="top">
                <field name="name"/>
                <field name="dialog_id"/>
                <field name="step_id"/>
                <field name="active"/>
                <field name="media_type"/>
            </tree></field>
    </record>
    <record id="kw_chatbot_builder_kw_chatbot_step_media_action_window" model="ir.actions.act_window">
        <field name="name">Step Media</field>
        <field name="res_model">kw.chatbot.step.media</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new chatbot step media
            </p></field>
    </record>
    <menuitem action="kw_chatbot_builder_kw_chatbot_step_media_action_window" groups="base.group_no_one" id="kw_chatbot_builder_kw_chatbot_step_media_menu" name="Step mediaes" parent="kw_chatbot.kw_chatbot_settings_main_menu" sequence="750"/>
</odoo>
