    <menuitem id="kw_chatbot_builder_kw_chatbot_conversation_no_reply_menu"
              action="kw_chatbot_builder_kw_chatbot_conversation_no_reply_action_window"
              parent="kw_chatbot.kw_chatbot_main_menu"
              name="No Reply" sequence="310"/>
