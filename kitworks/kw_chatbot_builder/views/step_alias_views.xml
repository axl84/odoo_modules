<odoo>
    <record id="kw_chatbot_builder_kw_chatbot_step_alias_form" model="ir.ui.view">
        <field name="name">kw.chatbot.step.alias.form (kw_chatbot_builder)</field>
        <field name="model">kw.chatbot.step.alias</field>
        <field name="arch" type="xml">
            <form>
                <header/>
                <sheet>
                    <div name="button_box" class="oe_button_box"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="step_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="dialog_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook/>
                </sheet>
                <field name="active" invisible="1"/>
            </form>
        </field>
    </record>

    <record id="kw_chatbot_builder_kw_chatbot_step_alias_tree" model="ir.ui.view">
        <field name="name">kw.chatbot.step.alias.tree (kw_chatbot_builder)</field>
        <field name="model">kw.chatbot.step.alias</field>
        <field name="arch" type="xml">
            <tree editable="top">
                <field name="name"/>
                <field name="dialog_id"/>
                <field name="step_id"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="kw_chatbot_builder_kw_chatbot_step_alias_action_window"
            model="ir.actions.act_window">
        <field name="name">Step aliases</field>
        <field name="res_model">kw.chatbot.step.alias</field>
        <field name='view_mode'>tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new chatbot step alias
            </p>
        </field>
    </record>

    <menuitem id="kw_chatbot_builder_kw_chatbot_step_alias_menu"
              action="kw_chatbot_builder_kw_chatbot_step_alias_action_window"
              parent="kw_chatbot.kw_chatbot_settings_main_menu"
              groups="base.group_no_one"
              name="Step aliases" sequence="700"/>
</odoo>
