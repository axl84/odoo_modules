<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="kw_chatbot_survey_telegram_chatbot_step_telegram_button_form" model="ir.ui.view">
        <field name="name">kw.chatbot.step.telegram.button.form (kw_chatbot_survey_telegram)</field>
        <field name="model">kw.chatbot.step.telegram.button</field>
        <field name="inherit_id" ref="kw_chatbot_builder_telegram.kw_chatbot_step_telegram_button_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="attributes">
                <attribute name="invisible">state == 'survey'</attribute>
            </xpath>
            <xpath expr="//notebook" position="after">
                <notebook>
                    <page invisible="state != 'survey'" name="survey" string="Survey">
                        <group>
                            <field name="survey_id" required="state == 'survey'"/>
                            <field invisible="1" name="related_fields_ids"/>
                            <field domain="[('id', 'in', related_fields_ids)]" invisible="related_fields_ids == False" name="related_fields_id"/>
                            <field name="entity_model_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="message_end_survey"/>
                            <field force_save="True" name="send_end_survey_button" readonly="return_step_type == 'notification'"/>
                            <field name="return_step_type"/>
                            <field invisible="return_step_type != 'step'" name="survey_next_step_id"/>
                            <field invisible="return_step_type != 'notification'" name="survey_next_notification_id"/>
                        </group>
                    </page>
                </notebook>
            </xpath></field>
    </record>
</odoo>
