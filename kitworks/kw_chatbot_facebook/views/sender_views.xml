<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="kw_chatbot_facebook_kw_chatbot_sender_form" model="ir.ui.view">
        <field name="name">kw.chatbot.sender.form (kw_chatbot_facebook)</field>
        <field name="model">kw.chatbot.sender</field>
        <field name="inherit_id" ref="kw_chatbot.kw_chatbot_kw_chatbot_sender_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page invisible="provider != 'facebook'" string="facebook">
                    <group>
                        <field name="facebook_id"/>
                    </group>
                </page>
            </notebook></field>
    </record>
</odoo>
