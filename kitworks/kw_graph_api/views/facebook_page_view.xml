<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="kw_graph_api_kw_facebook_page_search" model="ir.ui.view">
        <field name="name">kw.facebook.page.search (kw_graph_api)</field>
        <field name="model">kw.facebook.page</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="net_object"/>
                <field name="page_id"/>
                <searchpanel>
                    <field enable_counters="1" icon="fa-tag" name="net_object" select="multi" string="Networks"/>
                </searchpanel>
            </search></field>
    </record>
    <record id="kw_graph_api_kw_facebook_page_tree" model="ir.ui.view">
        <field name="name">kw.facebook.page.tree (kw_graph_api)</field>
        <field name="model">kw.facebook.page</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="net_object"/>
                <field name="page_id"/>
                <field name="facebook_app_id"/>
            </tree></field>
    </record>
    <record id="kw_graph_api_kw_facebook_page_form" model="ir.ui.view">
        <field name="name">kw.facebook.page.form (kw_graph_api)</field>
        <field name="model">kw.facebook.page</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button class="btn btn-primary" name="resubscribe_page" string="Resubscribe" type="object"/>
                </header>
                <sheet>
                    <widget bg_color="bg-danger" invisible="active == True" name="web_ribbon" title="Archived"/>
                    <field invisible="1" name="active"/>
                    <div name="title_line" style="width: 100%">
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                    </div>
                    <group>
                        <field name="net_object"/>
                        <field invisible="1" name="is_facebook_webhook"/>
                        <field invisible="1" name="page_webhook_token"/>
                        <field invisible="1" name="instagram_webhook_token"/>
                        <field name="facebook_app_id"/>
                        <!--                        <field name="is_developer_mode" groups="kw_graph_api.group_kw_facebook_admin"/>-->
                        <field name="is_developer_mode"/>
                        <field invisible="is_developer_mode == False" name="page_id"/>
                        <field invisible="is_developer_mode == False" name="access_token"/>
                    </group>
                    <notebook>
                        <page string="Settings">
                            <group string="CRM">
                                <group>
                                    <field name="crm_user_id"/>
                                    <field name="crm_team_id"/>
                                    <field name="crm_type"/>
                                    <field name="crm_medium_id"/>
                                    <field name="crm_source_id"/>
                                    <field name="crm_name_prefix"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form></field>
    </record>
    <record id="kw_graph_api_kw_facebook_page_action_window" model="ir.actions.act_window">
        <field name="name">Facebook Page</field>
        <field name="res_model">kw.facebook.page</field>
        <field name="view_mode">tree,form,search</field>
    </record>
    <menuitem action="kw_graph_api_kw_facebook_page_action_window" groups="kw_graph_api.group_kw_facebook_user" id="kw_facebook_pages_menu" name="Pages" parent="kw_facebook_main_menu" sequence="100"/>
</odoo>
