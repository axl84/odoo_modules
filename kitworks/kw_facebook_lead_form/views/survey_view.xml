<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="kw_facebook_lead_survey_tree" model="ir.ui.view">
        <field name="name">survey.survey.tree (kw_facebook_lead_form)</field>
        <field name="model">survey.survey</field>
        <field eval="10" name="priority"/>
        <field name="inherit_id" ref="survey.survey_survey_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='title']" position="after">
                <field name="kw_facebook_page_id" optional="show"/>
            </xpath></field>
    </record>
    <record id="kw_facebook_lead_survey_form" model="ir.ui.view">
        <field name="name">survey.survey.form (kw_facebook_lead_form)</field>
        <field name="model">survey.survey</field>
        <field eval="10" name="priority"/>
        <field name="inherit_id" ref="survey.survey_survey_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button class="btn btn-primary" invisible="kw_facebook_page_id == False" name="get_facebook_lead" string="Get Leads" type="object"/>
            </xpath>
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="kw_facebook_page_id"/>
                <field invisible="1" name="is_active_lead_form" widget="boolean_toggle"/>
            </xpath>
            <xpath expr="/form/sheet/div[hasclass('oe_button_box')]" position="inside">
                <button class="oe_stat_button" icon="fa-star" invisible="kw_facebook_page_id == False" name="facebook_crm_lead_action" type="object">
                    <field name="facebook_lead_count" string="Leads" widget="statinfo"/>
                </button>
            </xpath></field>
    </record>
    <record id="kw_facebook_lead_survey_survey_action" model="ir.actions.act_window">
        <field name="name">Facebook Lead Form</field>
        <field name="res_model">survey.survey</field>
        <field name="domain">[('is_facebook_forms','=',True)]</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem action="kw_facebook_lead_survey_survey_action" id="kw_facebook_lead_form_survey_survey_menu" name="Facebook Lead Form" parent="kw_graph_api.kw_facebook_lead_menu" sequence="100"/>
</odoo>
