<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="kw_chatbot_viber_kw_chatbot_viber_image_button_form" model="ir.ui.view">
        <field name="name">kw.chatbot.viber.image.button.form (kw_chatbot_viber)</field>
        <field name="model">kw.chatbot.viber.image.button</field>
        <field name="arch" type="xml">
            <form>
                <header/>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="is_used"/>
                        </group>
                        <group>
                            <field name="media_type"/>
                            <field name="image_scale_type"/>
                        </group>
                        <group>
                            <field name="media_image" widget="image"/>
                        </group>
                    </group>
                    <notebook/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="kw_chatbot_viber_kw_chatbot_viber_image_button_tree" model="ir.ui.view">
        <field name="name">kw.chatbot.viber.image.button.tree (kw_chatbot_viber)</field>
        <field name="model">kw.chatbot.viber.image.button</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="is_used"/>
                <field name="media_type"/>
                <field name="image_scale_type"/>
                <field name="media_image" widget="image" options='{"size": [300, 300]}'/>
            </tree>
        </field>
    </record>

    <record id="kw_chatbot_viber_kw_chatbot_viber_image_button_action_window"
            model="ir.actions.act_window">
        <field name="name">Viber Image Button</field>
        <field name="res_model">kw.chatbot.viber.image.button</field>
        <field name='view_mode'>tree,form</field>
    </record>

    <menuitem id="kw_chatbot_viber_image_button_menu"
              action="kw_chatbot_viber_kw_chatbot_viber_image_button_action_window"
              parent="kw_chatbot.kw_chatbot_settings_main_menu"
              groups="base.group_no_one"
              name="Setting Viber Image Button" sequence="910"/>
</odoo>
