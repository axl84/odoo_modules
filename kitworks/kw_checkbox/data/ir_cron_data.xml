<odoo noupdate="1">
    <record id="kw_cron_update_checkbox_shift_info" model="ir.cron">
        <field name="name">Update Checkbox Shift</field>
        <field eval="True" name="active"/>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="nextcall" eval="DateTime.now().strftime('%Y-%m-%d 22:30:00')"/>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="model_id" ref="model_kw_checkbox_shift"/>
        <field name="state">code</field>
        <field name="code">model.cron_update_checkbox_shift_info()</field>
    </record>
</odoo>
