<odoo>
    <record id="kw_chatbot_viber_kw_chatbot_builder_kw_chatbot_step_form" model="ir.ui.view">
        <field name="name">kw.chatbot.step.form (kw_chatbot_viber)</field>
        <field name="model">kw.chatbot.step</field>
        <field name="inherit_id"
               ref="kw_chatbot_builder.kw_chatbot_builder_kw_chatbot_step_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Viber Keyboard" groups="base.group_no_one">
                    <field name="viber_keyboard_ids"/>
                </page>
                <page string="Viber Buttons" groups="base.group_no_one">
                    <field name="viber_button_ids"/>
                </page>
            </notebook>
        </field>
    </record>
</odoo>
