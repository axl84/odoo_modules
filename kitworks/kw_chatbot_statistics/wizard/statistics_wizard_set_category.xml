<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="statistics_wizard_set_category_form_view" model="ir.ui.view">
        <field name="model">statistics.wizard.set.category</field>
        <field name="arch" type="xml">
            <form>

                <field name="is_not_elements" readonly="1" invisible="True"/>

                <group invisible="is_not_elements == True">
                    <group>
                        <field name="operator_id" readonly="1"/>
                        <field name="chat_id" readonly="1"/>
                        <field name="dialog_id" readonly="1"/>
                        <field name="conversation_id" readonly="1"/>
                        <field name="sender_id" readonly="1"/>
                        <field name="date_start" readonly="1"/>
                        <field name="date_end" readonly="1"/>
                    </group>
                    <group>
                        <field name="category_id"
                               options="{'no_create': True, 'no_quick_create': True}"
                               required="True"/>
                    </group>

                </group>

                <div invisible="is_not_elements == False" style="text-align: center;">
                    <p>No statistics records to set the category</p>
                </div>

                <footer>
                    <button string="Set Category"
                            name="action_set_category"
                            class="btn-primary"
                            type="object"
                            invisible="is_not_elements == True"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_statistics_wizard_set_category" model="ir.actions.act_window">
        <field name="name">Set Category</field>
        <field name="res_model">statistics.wizard.set.category</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
