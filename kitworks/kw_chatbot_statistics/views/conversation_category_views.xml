<odoo>

    <record id="kw_chatbot_kw_chatbot_conversation_category_form" model="ir.ui.view">
        <field name="name">kw.chatbot.conversation.category.form (kw_chatbot)</field>
        <field name="model">kw.chatbot.conversation.category</field>
        <field name="arch" type="xml">
            <form>
                <header/>
                <sheet>
                    <div name="button_box" class="oe_button_box"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Name"/>
                        </h1>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="kw_chatbot_kw_chatbot_conversation_category_tree" model="ir.ui.view">
        <field name="name">kw.chatbot.conversation.category.tree (kw_chatbot)</field>
        <field name="model">kw.chatbot.conversation.category</field>
        <field name="arch" type="xml">
            <tree>
                <field name="id" />
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="kw_chatbot_conversation_category_action_window"
            model="ir.actions.act_window">
        <field name="name">Conversation Categories</field>
        <field name="res_model">kw.chatbot.conversation.category</field>
        <field name='view_mode'>tree,form</field>
    </record>

    <menuitem id="kw_chatbot_conversation_category_menu"
              name="Conversation Categories"
              parent="kw_chatbot.kw_chatbot_settings_main_menu"
              action="kw_chatbot_conversation_category_action_window"
              sequence="980"/>

</odoo>
