<odoo>
    <record id="kw_chatbot_telegram_builder_sale_kw_chatbot_step_form" model="ir.ui.view">
        <field name="name">kw.chatbot.step.form (kw_chatbot_builder_telegram_sale)</field>
        <field name="model">kw.chatbot.step</field>
        <field name="inherit_id"
               ref="kw_chatbot_builder_sale.kw_chatbot_builder_sale_kw_chatbot_step_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='filter_category_domain']" position="after">
                <field name="buttons_category_ids" widget="many2many_tags"
                       options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>
</odoo>
