<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="kw_chatbot_login_in_system_kw_chatbot_builder_kw_chatbot_step_form" model="ir.ui.view">
        <field name="name">kw.chatbot.step.form (kw_chatbot_login_in_system)</field>
        <field name="model">kw.chatbot.step</field>
        <field name="inherit_id" ref="kw_chatbot_builder.kw_chatbot_builder_kw_chatbot_step_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='step_type']" position="after">
                <field invisible="step_type != 'login_in_system'" name="msg_after_login"/>
                <field invisible="step_type != 'login_in_system'" name="msg_after_unsuccessful_login"/>
                <field invisible="step_type != 'login_in_system'" name="go_to_step_unsuccessful_login"/>
            </xpath></field>
    </record>
</odoo>
