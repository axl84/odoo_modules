<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_journal_kw_bank_import_autoclient_privat24_form" model="ir.ui.view">
        <field name="name">account.journal.kw.import.form</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form//sheet" position="before">
                <header>
                    <button class="oe_highlight" invisible="bank_statements_source != 'privat24_autoclient'" name="kw_privat24_init_sync" string="Init sync" type="object"/>
                    <button class="oe_highlight" invisible="bank_statements_source != 'privat24_autoclient'" name="kw_privat24_self_sync" string="Manual sync" type="object"/>
                </header>
            </xpath>
            <xpath expr="//group[@name='bank_account_number']/field[@name='bank_statements_source']" position="after">
                <field invisible="bank_statements_source != 'privat24_autoclient'" name="kw_privat24_downloading_date"/>
            </xpath></field>
    </record>
</odoo>
