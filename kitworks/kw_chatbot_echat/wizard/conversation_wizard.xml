<odoo>
    <record id="kw_conversation_wizard_echat_views_form"
            model="ir.ui.view">
        <field name="name">kw.conversation.wizard.echat.form</field>
        <field name="model">kw.conversation.wizard.echat</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="partner_id"/>
                        <field name="mobile"/>
                        <field name="chat_ids" widget="many2many_tags" domain="[('provider','=','echat')]"/>
                        <field name="text"/>
                    </group>
                </sheet>
                <footer>
                    <button name="add_conversation"
                            type="object" class="oe_highlight"
                            string="Add"/>
                    <button special="cancel"
                            string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
