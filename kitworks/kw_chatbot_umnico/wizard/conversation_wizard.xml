<odoo>
    <record id="kw_conversation_wizard_umnico_views_form"
            model="ir.ui.view">
        <field name="name">kw.conversation.wizard.umnico.form</field>
        <field name="model">kw.conversation.wizard.umnico</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="partner_id"/>
                        <field name="mobile"/>
                        <field name="messenger_id" force_save="1"/>
                        <field name="umnico_channel_id" options="{'no_create': True, 'no_create':True}"/>
                        <field name="text_message"/>
                    </group>
                </sheet>
                <footer>
                    <button name="add_conversation"
                            type="object" class="oe_highlight"
                            string="Send"/>
<!--                    <button name="conversation_action_button"-->
<!--                            type="object" class="oe_highlight"-->
<!--                            string="Chat"/>-->
                    <button special="cancel"
                            string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
